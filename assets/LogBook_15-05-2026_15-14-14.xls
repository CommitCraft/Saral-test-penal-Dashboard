
      <html xmlns:o="urn:schemas-microsoft-com:office:office"
            xmlns:x="urn:schemas-microsoft-com:office:excel"
            xmlns="http://www.w3.org/TR/REC-html40">
      <head>
        <meta charset="UTF-8">
        <!--[if gte mso 9]>
        <xml>
          <x:ExcelWorkbook>
            <x:ExcelWorksheets>
              <x:ExcelWorksheet>
                <x:Name>Log Book</x:Name>
                <x:WorksheetOptions>
                  <x:DisplayGridlines/>
                  <x:FreezePanes/>
                  <x:FrozenNoSplit/>
                  <x:SplitHorizontal>2</x:SplitHorizontal>
                  <x:TopRowBottomPane>2</x:TopRowBottomPane>
                </x:WorksheetOptions>
              </x:ExcelWorksheet>
            </x:ExcelWorksheets>
          </x:ExcelWorkbook>
        </xml>
        <![endif]-->
        <style>
          table {
            border-collapse: collapse;
            width: 100%;
            font-family: Arial, sans-serif;
            font-size: 22px;
          }

          th, td {
            border: 1px solid #bfc7d1;
            padding: 6px 8px;
            text-align: center;
            vertical-align: middle;
            white-space: nowrap;
            font-size: 22px;
          }

          thead tr:first-child th {
            background: #1d4ed8;
            color: #ffffff;
            font-weight: bold;
            font-size: 23px;
          }

          thead tr:nth-child(2) th {
            background: #dbeafe;
            color: #111827;
            font-weight: bold;
            font-size: 22px;
          }

          tbody tr:nth-child(even) td {
            background: #f8fafc;
          }

          .pass {
            background: #dcfce7 !important;
            color: #166534 !important;
            font-weight: bold;
          }

          .fail {
            background: #fee2e2 !important;
            color: #991b1b !important;
            font-weight: bold;
          }

          .excel-text {
            mso-number-format: "\@";
          }
        </style>
      </head>
      <body>
        <table>
      <thead>
        
            <tr>
              <th colspan="5">General Info</th>

              <th colspan="2">LVS</th>
              <th colspan="4">ECR</th>
              <th colspan="4">HV / IR / LC</th>
              <th colspan="3">Stage 1</th>
              <th colspan="3">Stage 2</th>
              <th colspan="3">Stage 3</th>

              <th colspan="3">Swing</th>
              <th colspan="1">Final</th>

              <th colspan="6">RPM</th>
            </tr>

            <tr>
              <th data-col="1" class="sticky-col-1">Timestamp</th>
              <th data-col="2" class="sticky-col-2">Operator</th>
              <th data-col="3" class="sticky-col-3">Product Code</th>
              <th data-col="4" class="sticky-col-4">Model</th>
              <th data-col="5" class="sticky-col-5">Product SN</th>

              <th>LVS Volt (V)</th>
              <th>LVS Status</th>

              <th>ECR Volt (V)</th>
              <th>ECR Current (A)</th>
              <th>ECR Value (Ω)</th>
              <th>ECR Status</th>

              <th>HV</th>
              <th>IR</th>
              <th>LC Value (mA)</th>
              <th>LC</th>

              <th>S1 Volt (V)</th>
              <th>S1 Wattage (W)</th>
              <th>S1 Status</th>

              <th>S2 Volt (V)</th>
              <th>S2 Wattage (W)</th>
              <th>S2 Status</th>

              <th>S3 Volt (V)</th>
              <th>S3 Wattage (W)</th>
              <th>S3 Status</th>

              <th>Swing Volt (V)</th>
              <th>Swing Wattage (W)</th>
              <th>Swing Status</th>

              <th>Final Result</th>

              <th>RPM S1</th>
